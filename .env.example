# The public-facing URL of this admin app (used for auth callback redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Base URL for API calls (can differ from APP_URL in production)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...

# Google Maps (used for address search and map pin on the create-listing page)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Database (Prisma / direct connection)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
